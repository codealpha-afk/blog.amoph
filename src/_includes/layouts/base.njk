<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{{ title }} | Ancient Martinist Order Philippines</title>
  <meta name="description" content="{{ description }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://amoph.org{{ page.url }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://amoph.org{{ page.url }}">
  <meta property="og:title" content="{{ title }} | Ancient Martinist Order Philippines">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="https://amoph.org/images/og-images/amoph-og-image.jpg">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&family=Libre+Baskerville:ital@0;1&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/styles.css">

  <link rel="icon" type="image/ico" href="/images/logos/favicon.ico">
  <link rel="apple-touch-icon" href="/images/logos/favicon.ico">

  {% block head %}{% endblock %}
</head>
<body>

  {% include "partials/header.html" %}

  {{ content | safe }}

  {% include "partials/footer.html" %}

  <script src="/js/script.js"></script>
  {% block scripts %}{% endblock %}

</body>
</html>
